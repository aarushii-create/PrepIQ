# MySQL connection (PyMySQL driver)
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/interview_prep

EMBEDDING_MODEL=all-MiniLM-L6-v2
SKILL_MATCH_THRESHOLD=0.70

# Set to True for local development with Ollama running.
# Set to False when deploying to free hosting (Render, Railway free tier, etc.)
# — those environments can't run Ollama (no persistent server, limited RAM,
# no GPU), so leave this False there and rely on the curated question DB.
ENABLE_LLM_QUESTION_GENERATION=True

API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

ADMIN_TOKEN=replace-with-a-long-random-secret
